# TRAVAS-AI Environment Configuration

# Anthropic Claude API
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# OpenAI (for future integrations)
OPENAI_API_KEY=your-openai-api-key-here

# Google Gemini (for future integrations)
GOOGLE_API_KEY=your-google-api-key-here

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=logs/travas.log

# LLM Configuration
DEFAULT_LLM_PROVIDER=anthropic
DEFAULT_MODEL=claude-3-5-sonnet-20241022

# Data Configuration
HOTEL_DATA_SOURCE=local
HOTEL_API_URL=https://api.example.com/hotels

# Flask/Node Configuration
FLASK_ENV=development
PORT=5000

# Debugging
DEBUG=False
VERBOSE=False
EOF
